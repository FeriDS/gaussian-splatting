Bootstrap: docker
From: nvidia/cuda:11.8.0-devel-ubuntu22.04

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1
    export CUDA_HOME=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

%post
    # Update and install dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        git \
        build-essential \
        cmake \
        libgl1-mesa-glx \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender-dev \
        libgomp1 \
        libgl1-mesa-glx \
        libglib2.0-0 \
        && rm -rf /var/lib/apt/lists/*

    # Install Python 3.10
    apt-get update && apt-get install -y --no-install-recommends \
        python3.10 \
        python3.10-dev \
        python3.10-venv \
        python3-pip \
        && rm -rf /var/lib/apt/lists/*

    # Create symbolic links for python
    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1

    # Upgrade pip
    pip install --upgrade pip setuptools wheel

    # Create working directory
    mkdir -p /workspace

%files
    # Copy requirements.txt if you have it
    requirements.txt /workspace/requirements.txt

%post
    # Install PyTorch with CUDA 11.8
    pip install torch==2.0.1 torchvision==0.15.2 torchaudio==2.0.2 \
        --index-url https://download.pytorch.org/whl/cu118

    # Install core dependencies
    pip install \
        numpy \
        plyfile \
        tqdm \
        opencv-python \
        joblib \
        scipy \
        matplotlib \
        imageio

%post
    # Note: Gaussian Splatting submodules will be installed at runtime
    # because they need to be compiled with the specific CUDA version
    # and will be mounted from the host

%runscript
    #!/bin/bash
    echo "========================================="
    echo "Gaussian Splatting Container"
    echo "CUDA Version: $(nvcc --version | grep release)"
    echo "PyTorch Version: $(python -c 'import torch; print(torch.__version__)')"
    echo "CUDA Available: $(python -c 'import torch; print(torch.cuda.is_available())')"
    echo "========================================="
    
    # Execute the command passed to the container
    exec "$@"

%labels
    Version 1.0
    Description Gaussian Splatting with CUDA 11.8
    PyTorch 2.0.1
